# 复制为 .env 后按需修改。
# BETTER_AUTH_SECRET 可使用 `pnpm run auth:secret` 生成。

# 基础配置
COOKIE_PREFIX="geshu"
BETTER_AUTH_SECRET="replace_with_generated_secret"

# Better Auth 地址
# 生产环境部署到固定域名时填写，例如 https://example.com。
BETTER_AUTH_URL=""
NEXT_PUBLIC_BETTER_AUTH_URL=""

# 构建与运行
# NEXT_OUTPUT 可选值为 standalone 或 export；不需要指定时可留空。
NEXT_OUTPUT="standalone"
NEXT_TELEMETRY_DISABLED="1"

# 可选：仅在接入 Redis 限流存储时填写。
REDIS_URL=""

# 可选：可信反向代理传入的真实客户端 IP 请求头。
# 留空时默认读取 x-client-ip 或 x-forwarded-for。
TRUSTED_CLIENT_IP_HEADER=""

# 手机号注册时生成临时邮箱所使用的域名
DEFAULT_EMAIL_DOMAIN="example.com"

# 短信配置
# IS_INTRANET 为 1 时使用内网短信通道，为 0 时使用阿里云短信。
IS_INTRANET="0"
QJP_SMS_URL=""
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
