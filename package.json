{
    "name": "geshu-next-template",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "polyfills": "node scripts/generatePolyfills.mjs",
        "predev": "node scripts/generatePolyfills.mjs",
        "dev": "sdnext dev next dev --turbopack --hostname 0.0.0.0",
        "prebuild": "node scripts/generatePolyfills.mjs",
        "build": "sdnext build next build",
        "build:docker": "node -e \"const { execFileSync, spawnSync } = require('node:child_process'); const { name } = require('./package.json'); const date = new Date(); const dateTag = [date.getFullYear(), String(date.getMonth() + 1).padStart(2, '0'), String(date.getDate()).padStart(2, '0')].join(''); const commitTag = execFileSync('git', ['rev-parse', 'HEAD'], { encoding: 'utf8' }).trim().slice(0, 8); const image = ['luzixu', name].join('/'); const images = ['latest', dateTag, commitTag].map(tag => [image, tag].join(':')); function run(args) { const result = spawnSync('docker', args, { stdio: 'inherit' }); if (result.status !== 0) process.exit(result.status ?? 1); } run(['build', ...images.flatMap(image => ['-t', image]), '.']); images.forEach(image => run(['push', image]));\"",
        "start": "next start",
        "auth:secret": "node -e \"console.log(require('node:crypto').randomBytes(32).toString('hex'))\"",
        "lint": "eslint .",
        "format": "prettier --write .",
        "fg": "npm run format && git add . && git commit -m \"feat: format\"",
        "prepare": "husky",
        "migrate": "cross-env NODE_ENV=development prisma migrate dev",
        "db:dev": "cross-env NODE_ENV=development prisma migrate deploy",
        "db:prod": "cross-env NODE_ENV=production prisma migrate deploy",
        "studio:dev": "cross-env NODE_ENV=development prisma studio",
        "studio:prod": "cross-env NODE_ENV=production prisma studio"
    },
    "dependencies": {
        "@1adybug/xlsx": "^0.20.3",
        "@alicloud/dysmsapi20170525": "^4.6.0",
        "@alicloud/openapi-client": "^0.4.15",
        "@alicloud/tea-util": "^1.4.11",
        "@ant-design/cssinjs": "^2.1.2",
        "@ant-design/nextjs-registry": "^1.3.0",
        "@aws-sdk/client-s3": "^3.1086.0",
        "@fontsource-variable/noto-sans-sc": "^5.3.0",
        "@prisma/adapter-better-sqlite3": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@tabler/icons-react": "^3.44.0",
        "@tanstack/react-query": "^5.101.2",
        "@uiw/react-json-view": "2.0.0-alpha.43",
        "antd": "^6.5.1",
        "better-auth": "^1.6.23",
        "better-sqlite3": "^12.11.1",
        "core-js": "^3.49.0",
        "dayjs": "^1.11.21",
        "deepsea-tools": "^5.48.5",
        "next": "^16.2.10",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "soda-antd": "^1.0.37",
        "soda-hooks": "^6.19.1",
        "soda-next": "^0.7.39",
        "soda-tailwind": "^0.0.5",
        "soda-tanstack-query": "^0.0.16",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@1adybug/eslint": "^0.0.14",
        "@1adybug/prettier": "^0.0.33",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^24.13.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "autoprefixer": "^10.5.2",
        "browserslist": "^4.28.6",
        "core-js-compat": "^3.49.0",
        "cross-env": "^10.1.0",
        "eslint": "^9.39.5",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "postcss": "^8.5.19",
        "postcss-load-config": "^6.0.1",
        "prettier": "^3.9.5",
        "prisma": "^7.8.0",
        "sdnext": "^0.0.37",
        "tailwindcss": "^3.4.19",
        "typescript": "^6.0.3"
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    }
}
