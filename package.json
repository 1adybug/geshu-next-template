{
    "name": "geshu-next-template",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "sdnext dev next dev --turbopack --hostname 0.0.0.0",
        "build": "sdnext build next build",
        "build:docker": "node -e \"const { spawnSync } = require('node:child_process'); const { name } = require('./package.json'); const date = new Date(); const tag = [date.getFullYear(), String(date.getMonth() + 1).padStart(2, '0'), String(date.getDate()).padStart(2, '0')].join(''); const image = ['luzixu', name].join('/'); const latestImage = [image, 'latest'].join(':'); const datedImage = [image, tag].join(':'); function run(args) { const result = spawnSync('docker', args, { stdio: 'inherit' }); if (result.status !== 0) process.exit(result.status ?? 1); } run(['build', '-t', latestImage, '-t', datedImage, '.']); run(['push', latestImage]); run(['push', datedImage]);\"",
        "start": "next start",
        "auth:secret": "node -e \"console.log(require('node:crypto').randomBytes(32).toString('hex'))\"",
        "lint": "eslint .",
        "format": "prettier --write .",
        "fg": "pnpm run format && git add . && git commit -m \"✨feature: format\"",
        "prepare": "husky",
        "migrate": "cross-env NODE_ENV=development prisma migrate dev",
        "db:dev": "cross-env NODE_ENV=development prisma migrate deploy",
        "db:prod": "cross-env NODE_ENV=production prisma migrate deploy",
        "studio:dev": "cross-env NODE_ENV=development prisma studio",
        "studio:prod": "cross-env NODE_ENV=production prisma studio"
    },
    "dependencies": {
        "@alicloud/dysmsapi20170525": "^4.5.1",
        "@alicloud/openapi-client": "^0.4.15",
        "@alicloud/tea-util": "^1.4.11",
        "@ant-design/cssinjs": "^2.1.2",
        "@ant-design/nextjs-registry": "^1.3.0",
        "@aws-sdk/client-s3": "^3.1073.0",
        "@prisma/adapter-better-sqlite3": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@tabler/icons-react": "^3.44.0",
        "@tanstack/react-query": "^5.101.0",
        "@uiw/react-json-view": "2.0.0-alpha.43",
        "antd": "^6.4.5",
        "better-auth": "^1.6.20",
        "better-sqlite3": "^12.11.1",
        "dayjs": "^1.11.21",
        "deepsea-tools": "^5.48.2",
        "next": "^16.2.9",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "soda-antd": "^1.0.33",
        "soda-hooks": "^6.18.1",
        "soda-next": "^0.7.35",
        "soda-tailwind": "^0.0.5",
        "soda-tanstack-query": "^0.0.16",
        "source-han-sans-sc-vf": "^0.0.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@1adybug/eslint": "^0.0.11",
        "@1adybug/prettier": "^0.0.30",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^24.13.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "autoprefixer": "^10.5.0",
        "cross-env": "^10.1.0",
        "eslint": "^9.39.4",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "postcss": "^8.5.15",
        "postcss-load-config": "^6.0.1",
        "prettier": "^3.8.4",
        "prisma": "^7.8.0",
        "sdnext": "^0.0.34",
        "tailwindcss": "^3.4.19",
        "typescript": "^6.0.3"
    },
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    }
}
